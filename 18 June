5. // 2 sum II problem using 2 pointer approach


import java.util.*;
public class sort{
    public static int[]twosum(int[] nums,int target){
        int left=0;
        int right=nums.length-1;
        while(left<right){
            int sum=nums[left]+nums[right]; // remember
            if(sum==target){
                return new int[]{left,right};// remember new
            }
            else if(sum>target){
                right--;
            }
            else{
                left++;
            }

        }
        return new int[]{-1,-1}; // remember
    }
    public static void main(String args[]){
        int nums[]={2,7,9,11};
        int target=11;
        int ans[]=twosum(nums,target);
        System.out.println(ans[0]+" "+ ans[1]);
    }
}

